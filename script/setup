#!/usr/bin/env bash
# Set up the development environment for petsafe-homeassistant
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
VENV_DIR="/home/vscode/.local/ha-venv"
PY="$VENV_DIR/bin/python"
PIP="$VENV_DIR/bin/pip"
REQUIRED_PYTHON_MINOR="3.14"
REQUIRED_PYTHON_VERSION="3.14.2"

update_pyenv() {
  if command -v pyenv >/dev/null 2>&1; then
    PYENV_ROOT="$(pyenv root)"
    if [ -d "$PYENV_ROOT/.git" ]; then
      echo "Updating pyenv so Python $REQUIRED_PYTHON_VERSION is available..." >&2
      git -C "$PYENV_ROOT" fetch --tags origin >&2
      git -C "$PYENV_ROOT" pull --ff-only origin master >&2
    fi
  fi
}

resolve_python() {
  if command -v pyenv >/dev/null 2>&1; then
    if pyenv prefix "$REQUIRED_PYTHON_VERSION" >/dev/null 2>&1; then
      PYENV_PYTHON="$(pyenv prefix "$REQUIRED_PYTHON_VERSION")/bin/python${REQUIRED_PYTHON_MINOR}"
      if [ -x "$PYENV_PYTHON" ]; then
        printf "%s\n" "$PYENV_PYTHON"
        return
      fi
    fi

    update_pyenv
    echo "Installing Python $REQUIRED_PYTHON_VERSION with pyenv for the dev environment..." >&2
    pyenv install -s "$REQUIRED_PYTHON_VERSION" >&2
    PYENV_PYTHON="$(pyenv prefix "$REQUIRED_PYTHON_VERSION")/bin/python${REQUIRED_PYTHON_MINOR}"
    if [ -x "$PYENV_PYTHON" ]; then
      printf "%s\n" "$PYENV_PYTHON"
      return
    fi
  fi

  if command -v python${REQUIRED_PYTHON_MINOR} >/dev/null 2>&1; then
    command -v python${REQUIRED_PYTHON_MINOR}
    return
  fi

  command -v python3
}

SYSTEM_PYTHON="$(resolve_python)"

cd "$REPO_ROOT"

# Mark the repository as safe for Git inside the container
git config --global --add safe.directory "$REPO_ROOT"

# Check container Python version before creating the venv
CURRENT_PYTHON="$($SYSTEM_PYTHON -c 'import sys; print(".".join(map(str, sys.version_info[:3])))')"
CURRENT_PYTHON_MINOR="$($SYSTEM_PYTHON -c 'import sys; print(f"{sys.version_info[0]}.{sys.version_info[1]}")')"

if [ "$CURRENT_PYTHON_MINOR" != "$REQUIRED_PYTHON_MINOR" ]; then
  echo "Resolved Python interpreter is $CURRENT_PYTHON via $SYSTEM_PYTHON, but this repo requires Python $REQUIRED_PYTHON_MINOR.x." >&2
  echo "Pin the container image/Dockerfile to Python $REQUIRED_PYTHON_MINOR, then rebuild the devcontainer." >&2
  exit 1
fi

# Recreate the venv if it exists but is not using the required minor version
if [ -x "$PY" ]; then
  CURRENT_VENV_MINOR="$("$PY" -c 'import sys; print(f"{sys.version_info[0]}.{sys.version_info[1]}")')"
  if [ "$CURRENT_VENV_MINOR" != "$REQUIRED_PYTHON_MINOR" ]; then
    CURRENT_VENV_VERSION="$("$PY" -c 'import sys; print(".".join(map(str, sys.version_info[:3])))')"
    echo "Existing virtualenv uses Python $CURRENT_VENV_VERSION; recreating with Python $REQUIRED_PYTHON_MINOR.x ..."
    rm -rf "$VENV_DIR"
  fi
fi

# Create the venv VS Code/devcontainer is configured to use
if [ ! -x "$PY" ]; then
  echo "Creating virtualenv at $VENV_DIR ..."
  "$SYSTEM_PYTHON" -m venv "$VENV_DIR"
  "$PY" -m pip install --upgrade pip wheel
fi

# Ensure uv and pre-commit are available in this venv
"$PIP" install --upgrade uv pre-commit

# Install project dependencies (install-only; do NOT start HA here)
"$REPO_ROOT/script/bootstrap" --no-run

# Install pre-commit hooks
"$VENV_DIR/bin/pre-commit" install

echo "Setup complete."