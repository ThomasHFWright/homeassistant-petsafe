#!/bin/bash

# script/test-critical: Run auth, polling, and SmartDoor tests
#
# Usage:
#   ./script/test-critical
#   ./script/test-critical -k reauth

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$SCRIPT_DIR/.."

"$SCRIPT_DIR/test" \
    tests/test_config_flow.py \
    tests/test_coordinator_auth.py \
    tests/test_feeder.py \
    tests/test_litterbox.py \
    tests/test_smartdoor.py \
    "$@"
