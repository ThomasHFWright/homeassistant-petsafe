{
  "config": {
    "step": {
      "user": {
        "data": {
          "email": "[%key:common::config_flow::data::email%]"
        }
      },
      "code": {
        "description": "Check your email for the confirmation code",
        "data": {
          "code": "Confirmation Code"
        }
      },
      "reauth_confirm": {
        "description": "Check {email} for the new confirmation code",
        "data": {
          "code": "Confirmation Code"
        }
      },
      "devices": {
        "data": {
          "feeders": "Feeders",
          "litterboxes": "Litterboxes",
          "smartdoors": "SmartDoors"
        }
      }
    },
    "error": {
      "cannot_connect": "[%key:common::config_flow::error::cannot_connect%]",
      "invalid_user": "Invalid email address",
      "invalid_code": "Invalid confirmation code",
      "unknown_error": "[%key:common::config_flow::error::unknown%]"
    },
    "abort": {
      "already_configured": "[%key:common::config_flow::abort::already_configured_device%]",
      "reauth_successful": "[%key:common::config_flow::abort::reauth_successful%]"
